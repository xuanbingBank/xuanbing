{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "lib": ["ES2020", "DOM"]
  },
  "include": ["electron/**/*.ts", "electron/**/*.d.ts", "src/**/*.ts", "types/**/*.d.ts"]
}
